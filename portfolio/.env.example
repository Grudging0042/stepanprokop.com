# Umami Analytics Configuration
# Get your Umami credentials from your Umami dashboard
# Self-hosted: https://your-umami-instance.com
# Cloud: https://cloud.umami.is

# Your Umami website URL (e.g., https://analytics.yourdomain.com)
NEXT_PUBLIC_UMAMI_URL=

# Your website ID from Umami dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional: Environment name for tracking (development, staging, production)
NEXT_PUBLIC_APP_ENV=development
